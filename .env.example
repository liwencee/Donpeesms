# ═══════════════════════════════════════════════════════════
# DonPeeSMS Backend — Environment Variables
# Copy this file to `.env` and fill in real values
# ═══════════════════════════════════════════════════════════

# ── SERVER ──
NODE_ENV=development
PORT=5000
APP_NAME=DonPeeSMS
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ── DATABASE (PostgreSQL via Prisma) ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/donpeesms
# Supabase:  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Neon.tech: postgresql://[USER]:[PASSWORD]@[HOST]/[DBNAME]?sslmode=require
# Railway:   postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/railway

# ── JWT ──
JWT_SECRET=replace_with_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=cookie_signing_secret_random_string

# ── BCRYPT ──
BCRYPT_ROUNDS=12

# ── EMAIL (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=DonPeeSMS
SMTP_FROM_EMAIL=noreply@donpeesms.io

# ── SMS PROVIDERS ──

# 5SIM (https://5sim.net)
FIVESIM_API_KEY=your_5sim_api_key
FIVESIM_BASE_URL=https://5sim.net/v1

# SMS-Activate (https://sms-activate.org)
SMSACTIVATE_API_KEY=your_sms_activate_key
SMSACTIVATE_BASE_URL=https://api.sms-activate.org/stubs/handler_api.php

# Twilio (fallback for outbound)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+15005550006

# SureVerifications (https://sureverifications.com) — PRIMARY
SURE_VERIFICATIONS_API_KEY=your_sureverifications_api_key
SURE_VERIFICATIONS_BASE_URL=https://sureverifications.com/api/v1

# Active provider: 'sureverifications' | 'fivesim' | 'smsactivate' | 'twilio'
SMS_PROVIDER=sureverifications

# ── STRIPE (Card payments) ──
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── NOWPAYMENTS (Crypto: USDT/BTC/ETH) ──
NOWPAYMENTS_API_KEY=your_nowpayments_key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# ── PAYPAL ──
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ── PRICING MARKUP ──
# Multiplier applied on top of provider price (e.g. 1.4 = 40% markup)
PRICE_MARKUP=1.4

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ── LOGGING ──
LOG_LEVEL=info

# Maintenance mode (true = show maintenance page; /admin stays reachable)
MAINTENANCE_MODE=false
